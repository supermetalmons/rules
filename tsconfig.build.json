{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": false,
    "emitDeclarationOnly": true,
    "noEmit": false,
    "outDir": "target/types",
    "rootDir": "src",
    "stripInternal": true,
    "types": ["node"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/cli/**", "src/**/*.test.ts"]
}
